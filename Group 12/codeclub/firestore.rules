rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection
    match /users/{userId} {
      // Users can read and write their own document
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Allow authenticated users to read other users' profiles for team matching
      // (needed for finding team members and viewing profiles)
      allow read: if request.auth != null;
      
      // Admins can read and write all user documents
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }
    
    // Teams collection
    match /teams/{teamId} {
      // Allow authenticated users to read all teams (for browsing/searching)
      allow read: if request.auth != null;
      
      // Allow creation of new teams based on actual team schema fields
      allow create: if request.auth != null && 
                      request.auth.uid == request.resource.data.leaderId &&
                      request.auth.uid in request.resource.data.memberIds;
      
      // Team leader, members, or admins can update/delete
      allow update, delete: if request.auth != null && 
                               (request.auth.uid == resource.data.leaderId ||
                                request.auth.uid in resource.data.memberIds ||
                                request.auth.token.admin == true);
    }
    
    // Team requests collection - FIXED: More permissive rules for requests
    match /teamRequests/{requestId} {
      // Allow authenticated users to read requests where they are sender or receiver
      allow read: if request.auth != null && 
                    (resource.data.fromUserId == request.auth.uid ||
                     resource.data.toUserId == request.auth.uid);
      
      // Also allow reading all requests for authenticated users (needed for checking existing requests)
      allow read: if request.auth != null;
      
      // Users can create requests
      allow create: if request.auth != null && 
                      request.resource.data.fromUserId == request.auth.uid;
      
      // Allow updates by sender or receiver
      allow update: if request.auth != null && 
                      (resource.data.fromUserId == request.auth.uid ||
                       resource.data.toUserId == request.auth.uid);
      
      // Allow deletes by sender only
      allow delete: if request.auth != null && 
                      resource.data.fromUserId == request.auth.uid;
    }

    // Team requests collection (underscore) - used by app service
    match /team_requests/{requestId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null &&
                      request.resource.data.fromUserId == request.auth.uid;

      allow update: if request.auth != null &&
                      (resource.data.fromUserId == request.auth.uid ||
                       resource.data.toUserId == request.auth.uid);

      allow delete: if request.auth != null &&
                      resource.data.fromUserId == request.auth.uid;
    }
    
    // Admins collection - admins can read their own document and all admin documents
    match /admins/{adminId} {
      // Admins can read their own admin document
      allow read: if request.auth != null && 
                     (request.auth.uid == adminId ||
                      request.auth.token.admin == true);
      
      // Admins can create/update/delete admin documents
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Legacy admin collection (singular) - kept for backward compatibility
    match /admin/{adminId} {
      allow read: if request.auth != null &&
                     (request.auth.uid == adminId ||
                      request.auth.token.admin == true);

      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    
    // Hackathons collection - everyone can read, admins can write
    match /hackathons/{hackathonId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Applications collection - students apply, admins manage
    match /applications/{applicationId} {
      allow read: if request.auth != null && 
                    (resource.data.userId == request.auth.uid ||
                     get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow create: if request.auth != null && 
                      request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && 
                      (resource.data.userId == request.auth.uid ||
                       get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow delete: if request.auth != null && 
                      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Chats collection - Updated for all chat types
    match /chats/{chatId} {
      // Allow creation of new chats
      allow create: if request.auth != null && 
                      (request.resource.data.createdBy == request.auth.uid ||
                       request.auth.uid in request.resource.data.participantIds);
      
      // Users can read chats they are participants of, community chats, or if they're an admin
      allow read: if request.auth != null && 
                    (request.auth.uid in resource.data.participantIds ||
                     (resource.data.chatType == 'team' &&
                      resource.data.teamId is string &&
                      exists(/databases/$(database)/documents/teams/$(resource.data.teamId)) &&
                      (request.auth.uid in get(/databases/$(database)/documents/teams/$(resource.data.teamId)).data.memberIds ||
                       request.auth.uid == get(/databases/$(database)/documents/teams/$(resource.data.teamId)).data.leaderId)) ||
                     resource.data.chatType == 'community' ||
                     request.auth.token.admin == true);
      
      // Participants can update chats, community chats can be updated by any authenticated user joining, or admins
      allow update: if request.auth != null && 
                      (request.auth.uid in resource.data.participantIds ||
                       resource.data.chatType == 'community' ||
                       request.auth.token.admin == true);
      
      // Creator, participants, or admins can delete
      allow delete: if request.auth != null && 
                      (resource.data.createdBy == request.auth.uid ||
                       request.auth.uid in resource.data.participantIds ||
                       request.auth.token.admin == true);
    }
    
    // Messages subcollection - Updated for community chats
    match /chats/{chatId}/messages/{messageId} {
      // Chat participants can read messages, community chat messages are public for authenticated users, or if admin
      allow read: if request.auth != null && 
                    (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds ||
                     get(/databases/$(database)/documents/chats/$(chatId)).data.chatType == 'community' ||
                     request.auth.token.admin == true);
      
      // Authenticated users can create messages if they're in the chat or it's a community chat, or if admin
      allow create: if request.auth != null && 
                       request.resource.data.senderId == request.auth.uid &&
                       (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantIds ||
                        get(/databases/$(database)/documents/chats/$(chatId)).data.chatType == 'community' ||
                        request.auth.token.admin == true);
      
      // Message sender can update/delete their own messages, or admins can delete
      allow update, delete: if request.auth != null && 
                              (resource.data.senderId == request.auth.uid ||
                               request.auth.token.admin == true);
    }
    
    // Community chats collection - special collection for global community chats
    match /communityChats/{chatId} {
      // All authenticated users can read community chats
      allow read: if request.auth != null;
      
      // Only admins can create community chats
      allow create: if request.auth != null;
      
      // Participants or admins can update
      allow update: if request.auth != null;
      
      // Only admins can delete
      allow delete: if request.auth != null && 
                      request.auth.token.admin == true;
    }
  }
}